# 平台托管开源模型（OpenAI-compatible HTTPS 推理服务）
AI_DEFAULT_PROVIDER=builtin
AI_BUILTIN_BASE_URL=https://your-inference-service.example/v1
AI_BUILTIN_MODEL=Qwen/Qwen3-8B
# AI_BUILTIN_API_KEY=

