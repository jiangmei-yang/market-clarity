# false：优先使用 AKShare 真实公开数据；true：只用固定演示资料
USE_DEMO_DATA=false
# false：ETF工具优先读取真实名单与定期披露；true：固定使用内置演示样本
ETF_USE_DEMO_DATA=false
# 单个 ETF 公开数据请求最多等待秒数；超时后自动使用缓存或明确标注的演示数据
ETF_UPSTREAM_TIMEOUT_SECONDS=5
DATABASE_PATH=data/anshin.db
DATA_CACHE_DIR=data/cache
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:8000,http://localhost:8000
# AI_PROVIDER=mock|openai|compatible (AI_REPORT_PROVIDER is a legacy alias)
AI_PROVIDER=mock
# AI_REPORT_PROVIDER=mock
AI_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# APP_PASSWORD、OPENAI_API_KEY 和 TUSHARE_TOKEN 请放入
# .streamlit/secrets.toml，不要写入 .env 或提交到 Git。
