# FastAPI 服务地址。本地默认端口为 8001；线上必须填写公开 HTTPS 地址。
ANXIN_API_URL=http://127.0.0.1:8001
DAILY_STOCK_ANALYSIS_URL=http://127.0.0.1:8000

# 可选：同花顺 iFinD 官方 HTTP API。二选一即可；不要提交真实 Token。
# IFIND_REFRESH_TOKEN=replace_with_server_secret
# IFIND_ACCESS_TOKEN=replace_with_short_lived_server_secret

# 平台默认优先使用托管的开源模型。它必须是真实、服务器可访问的 OpenAI-compatible 推理服务。
# 用户不需要填写 Key；若推理服务要求鉴权，Key 仅放 Sites Secrets。
AI_DEFAULT_PROVIDER=builtin
# AI_BUILTIN_BASE_URL=https://your-inference-service.example/v1
# AI_BUILTIN_MODEL=Qwen/Qwen3-8B
# AI_BUILTIN_API_KEY=

# 兼容旧版 HKGAI 平台配置。真实值只放在 Sites 环境变量，不提交到 Git。
AI_PROVIDER=compatible
AI_DISPLAY_NAME=HKGAI
OPENAI_BASE_URL=https://test-new-api.hkchat.app/v1
AI_MODEL=REPLACE_WITH_HKGAI_MODEL_NAME
# OPENAI_API_KEY=

# 加密用户自行提交的模型密钥。生产环境必须使用高强度随机值，并仅保存于 Sites Secrets。
# AI_PROVIDER_ENCRYPTION_KEY=

# 可选平台模型目录。用户也可在 /ai-settings 自行提交个人配置；密钥会在服务端加密。
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_DIRECT_API_KEY=
# OPENAI_DIRECT_MODEL=
# CLAUDE_API_KEY=
# CLAUDE_BASE_URL=
# CLAUDE_MODEL=
# 本机开发模式。部署后的 Sites Worker 无法访问用户电脑上的 127.0.0.1。
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=qwen3:8b
# VLLM_BASE_URL=http://127.0.0.1:8001/v1
# VLLM_MODEL=Qwen/Qwen3-8B
# VLLM_API_KEY=EMPTY
# LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
# LLAMACPP_MODEL=local-gguf
# CUSTOM_AI_API_KEY=
# CUSTOM_AI_BASE_URL=
# CUSTOM_AI_MODEL=
