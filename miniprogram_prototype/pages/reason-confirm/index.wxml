<view class="page">
  <view class="title">确认理由结构</view>
  <view class="warning">请检查系统是否误解。确认后才会计算仓位和检索证据。</view>
  <block wx:for="{{claims}}" wx:key="text">
    <view class="card">
      <view class="card-title">{{item.text}}</view>
      <view class="muted">需要：{{item.required_evidence}}</view>
      <picker range="{{typeNames}}" data-index="{{index}}" bindchange="changeType"><view class="input">分类：{{item.typeLabel}}</view></picker>
    </view>
  </block>
  <text class="label">系统理解的信息来源</text><input class="input" value="{{plan.source}}" data-key="source" bindinput="edit" />
  <text class="label">判断失效条件</text><input class="input" value="{{plan.invalidation}}" data-key="invalidation" bindinput="edit" />
  <button class="button-primary" loading="{{loading}}" bindtap="confirm">确认并生成第二意见</button>
  <button class="button-secondary" bindtap="back">返回修改</button>
</view>
